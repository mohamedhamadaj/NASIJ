@model ProductEditVM
@using TMAProject.ViewModels.Admin.ProductVM
@using TMAProject.Models.Enums
@{
    ViewData["Title"] = "Edit Product";
    ViewData["ActivePage"] = "Products";
}

<div class="content-header">
    <div>
        <h1 class="page-title">Edit Product</h1>
        <ul class="breadcrumbs">
            <li><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a></li>
            <li><a asp-area="Admin" asp-controller="Product" asp-action="Index">Products</a></li>
            <li class="active">Edit</li>
        </ul>
    </div>
</div>

<form asp-area="Admin" asp-controller="Product" asp-action="Edit"
      method="post" enctype="multipart/form-data" id="editProductForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ProductId" />

    <div class="form-grid-two-col">

        @* LEFT column *@
        <div class="form-column">

            @* Basic Info card *@
            <div class="card-glass form-card">
                <h3 class="form-card-title"><i class="fas fa-circle-info"></i> Basic Information</h3>

                <div class="form-group">
                    <label asp-for="Name" class="form-label">Product Name <span class="required-star">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Classic Denim Jacket" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control form-textarea"
                              placeholder="Describe the product details..."></textarea>
                    <span asp-validation-for="Description" class="field-error"></span>
                </div>

                <div class="form-row-two">
                    <div class="form-group">
                        <label asp-for="Price" class="form-label">Price ($) <span class="required-star">*</span></label>
                        <input asp-for="Price" type="number" step="0.01" min="0"
                               class="form-control" />
                        <span asp-validation-for="Price" class="field-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="DiscountPercentage" class="form-label">Discount (%)</label>
                        <input asp-for="DiscountPercentage" type="number" step="0.01" min="0" max="100"
                               class="form-control" />
                        <span asp-validation-for="DiscountPercentage" class="field-error"></span>
                    </div>
                </div>

                <div class="form-row-two">
                    <div class="form-group">
                        <label asp-for="CategoryId" class="form-label">Category <span class="required-star">*</span></label>
                        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-control form-select">
                            <option value="">— Select category —</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="field-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Status" class="form-label">Status</label>
                        <select asp-for="Status"
                                asp-items="Html.GetEnumSelectList<TMAProject.Models.Enums.ProductStatus>()"
                                class="form-control form-select"></select>
                        <span asp-validation-for="Status" class="field-error"></span>
                    </div>
                </div>
            </div>

            @* Color & Size Configurator (Variants) *@
            <div class="card-glass form-card">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
                    <h3 class="form-card-title" style="margin-bottom: 0;"><i class="fas fa-palette"></i> Colors &amp; Sizes Configuration</h3>
                    <button type="button" id="addColorBtn" class="btn-secondary-sm">
                        <i class="fas fa-plus"></i> Add Color Group
                    </button>
                </div>

                <div id="colorsContainer" style="display: flex; flex-direction: column; gap: 20px;">
                    @if (Model.ProductColors != null && Model.ProductColors.Count > 0)
                    {
                        for (int cIdx = 0; cIdx < Model.ProductColors.Count; cIdx++)
                        {
                            var colorGroup = Model.ProductColors[cIdx];
                            <div class="color-group card-glass" style="border: 1px solid var(--border-color); background: rgba(255, 255, 255, 0.02); padding: 20px; border-radius: 12px; position: relative;">
                                <input type="hidden" class="product-color-id-input" name="ProductColors[@cIdx].ProductColorId" value="@colorGroup.ProductColorId" />
                                <button type="button" class="btn-remove-color" style="position: absolute; top: 12px; right: 12px; background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s;" title="Remove Color Group">
                                    <i class="fas fa-trash-can" style="font-size: 0.8rem;"></i>
                                </button>

                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; margin-right: 28px;">
                                    <div class="form-group" style="margin-bottom: 0;">
                                        <label class="form-label">Color <span class="required-star">*</span></label>
                                        <select class="form-control form-select color-id-input" required name="ProductColors[@cIdx].ColorId">
                                            <option value="">— Choose Color —</option>
                                            @foreach (var c in Model.Colors)
                                            {
                                                if (c.Value == colorGroup.ColorId.ToString())
                                                {
                                                    <option value="@c.Value" selected>@c.Text</option>
                                                }
                                                else
                                                {
                                                    <option value="@c.Value">@c.Text</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    
                                    <div class="form-group" style="margin-bottom: 0;">
                                        <label class="form-label">Color-Specific Images</label>
                                        <input type="file" class="form-control color-images-input" accept="image/*" multiple style="padding: 6px 12px;" name="ProductColors[@cIdx].NewImages" />
                                        <div class="color-images-preview-grid" style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px;"></div>
                                    </div>
                                </div>

                                @if (colorGroup.ExistingImages != null && colorGroup.ExistingImages.Count > 0)
                                {
                                    <div style="margin-bottom: 16px;">
                                        <span style="font-size: 0.8rem; font-weight: 600; color: var(--text-muted); display: block; margin-bottom: 8px;">Existing Color Images</span>
                                        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                                            @for (int imgIdx = 0; imgIdx < colorGroup.ExistingImages.Count; imgIdx++)
                                            {
                                                var img = colorGroup.ExistingImages[imgIdx];
                                                <div class="existing-color-image-thumb" style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; border: 1px solid var(--border-color); position: relative;">
                                                    <img src="@img.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                                                    <input type="hidden" class="existing-image-id" name="ProductColors[@cIdx].ExistingImages[@imgIdx].ImageUrlId" value="@img.ImageUrlId" />
                                                    <input type="hidden" class="existing-image-url" name="ProductColors[@cIdx].ExistingImages[@imgIdx].ImageUrl" value="@img.ImageUrl" />
                                                    <button type="button" class="btn-remove-existing-color-image" style="position: absolute; top: 2px; right: 2px; background: rgba(0,0,0,0.6); color: #fff; border: none; border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 0.65rem;" title="Remove Image">
                                                        <i class="fas fa-xmark"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                <div style="border-top: 1px dashed var(--border-color); padding-top: 16px; margin-top: 16px;">
                                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                                        <h4 style="font-size: 0.9rem; font-weight: 700; margin: 0; color: var(--text-secondary);"><i class="fas fa-ruler"></i> Available Sizes &amp; Stock</h4>
                                        <button type="button" class="btn-secondary-sm add-size-btn" style="padding: 4px 10px; font-size: 0.75rem;">
                                            <i class="fas fa-plus"></i> Add Size
                                        </button>
                                    </div>

                                    <div class="sizes-container" style="display: flex; flex-direction: column; gap: 8px;">
                                        @if (colorGroup.Variants != null)
                                        {
                                            for (int sIdx = 0; sIdx < colorGroup.Variants.Count; sIdx++)
                                            {
                                                var variant = colorGroup.Variants[sIdx];
                                                <div class="variant-row" style="display: grid; grid-template-columns: 1fr 80px 60px auto; gap: 10px; align-items: center; background: rgba(0,0,0,0.1); padding: 8px 12px; border-radius: 8px;">
                                                    <input type="hidden" class="variant-id-input" name="ProductColors[@cIdx].Variants[@sIdx].VariantId" value="@variant.VariantId" />
                                                    <div class="form-group" style="margin-bottom: 0; gap: 4px;">
                                                        <select class="form-control form-select variant-size-select" required name="ProductColors[@cIdx].Variants[@sIdx].SizeId" style="padding: 6px 10px; font-size: 0.85rem;">
                                                            <option value="">— Size —</option>
                                                            @foreach (var s in Model.Sizes)
                                                            {
                                                                if (s.Value == variant.SizeId.ToString())
                                                                {
                                                                    <option value="@s.Value" selected>@s.Text</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="@s.Value">@s.Text</option>
                                                                }
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="form-group" style="margin-bottom: 0; gap: 4px;">
                                                        <input type="number" class="form-control variant-qty-input" min="0" placeholder="Qty" value="@variant.Quantity" required name="ProductColors[@cIdx].Variants[@sIdx].Quantity" style="padding: 6px 10px; font-size: 0.85rem;" />
                                                    </div>
                                                    <div class="form-group" style="margin-bottom: 0; display: flex; flex-direction: column; align-items: center; gap: 2px;">
                                                        <label class="form-label-sm" style="font-size: 0.7rem; margin: 0;">Active</label>
                                                        @if (variant.IsActive)
                                                        {
                                                            <input type="checkbox" class="form-checkbox variant-active-checkbox" checked value="true" name="ProductColors[@cIdx].Variants[@sIdx].IsActive" />
                                                        }
                                                        else
                                                        {
                                                            <input type="checkbox" class="form-checkbox variant-active-checkbox" value="true" name="ProductColors[@cIdx].Variants[@sIdx].IsActive" />
                                                        }
                                                    </div>
                                                    <button type="button" class="btn-remove-variant" style="padding: 6px; width: 28px; height: 28px; border-radius: 6px; font-size: 0.8rem; line-height: 1;" title="Remove Size">
                                                        <i class="fas fa-xmark"></i>
                                                    </button>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p id="noColorsMsg" style="color: var(--text-muted); font-size: 0.9rem; text-align: center; padding: 24px 0;">
                            No colors configured yet. Click "Add Color Group" to define colors, specific color images, and sizes.
                        </p>
                    }
                </div>
            </div>
        </div>

        @* RIGHT column *@
        <div class="form-column">

            @* Main image card *@
            <div class="card-glass form-card">
                <h3 class="form-card-title"><i class="fas fa-image"></i> Product Main Image</h3>

                @if (!string.IsNullOrEmpty(Model.ExistingMainImageUrl))
                {
                    <div class="image-preview-wrap" id="existingMainImageWrap" style="margin-bottom: 12px;">
                        <img src="@Model.ExistingMainImageUrl" alt="Current main image" class="image-preview-img" id="mainPreviewImg" />
                        <span class="image-current-label">Current Image</span>
                    </div>
                }

                <div class="image-upload-zone" id="mainImageZone">
                    <i class="fas fa-cloud-arrow-up upload-icon"></i>
                    <p class="upload-text">Click or drag &amp; drop to replace</p>
                    <p class="upload-subtext">PNG, JPG, WEBP — max 5 MB</p>
                    <input asp-for="MainImage" type="file" id="mainImageInput"
                           accept="image/*" class="file-input-hidden" />
                </div>
                <div id="newMainImagePreview" class="image-preview-wrap" style="display: none; margin-top: 12px;">
                    <img id="newMainPreviewImg" src="" alt="New Preview" class="image-preview-img" />
                    <button type="button" id="removeNewMainImage" class="btn-remove-image" title="Remove image">
                        <i class="fas fa-xmark"></i>
                    </button>
                </div>
                <span asp-validation-for="MainImage" class="field-error"></span>
            </div>

            @* General Sub images card *@
            <div class="card-glass form-card">
                <h3 class="form-card-title"><i class="fas fa-images"></i> Additional General Images</h3>

                @if (Model.ExistingSubImages != null && Model.ExistingSubImages.Count > 0)
                {
                    <span style="font-size: 0.8rem; font-weight: 600; color: var(--text-muted); display: block; margin-bottom: 8px;">Current Sub Images</span>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px;">
                        @foreach (var sub in Model.ExistingSubImages)
                        {
                            <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; border: 1px solid var(--border-color); position: relative;">
                                <img src="@sub.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                            </div>
                        }
                    </div>
                }

                <div class="image-upload-zone" id="subImagesZone">
                    <i class="fas fa-cloud-arrow-up upload-icon"></i>
                    <p class="upload-text">Click or drag &amp; drop to upload more</p>
                    <p class="upload-subtext">Select multiple images — PNG, JPG, WEBP</p>
                    <input asp-for="NewSubImages" type="file" id="subImagesInput"
                           accept="image/*" multiple class="file-input-hidden" />
                </div>
                <div id="newSubImagesGrid" class="sub-images-grid"></div>
                <span asp-validation-for="NewSubImages" class="field-error"></span>
            </div>

        </div>
    </div>

    <div class="form-actions">
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn-outline">
            <i class="fas fa-arrow-left"></i> Cancel
        </a>
        <button type="submit" class="btn-primary-gradient">
            <i class="fas fa-floppy-disk"></i> Save Changes
        </button>
    </div>
</form>

@* Templates for JS Variant Management *@
<template id="colorGroupTemplate">
    <div class="color-group card-glass" style="border: 1px solid var(--border-color); background: rgba(255, 255, 255, 0.02); padding: 20px; border-radius: 12px; position: relative;">
        <input type="hidden" class="product-color-id-input" value="" />
        <button type="button" class="btn-remove-color" style="position: absolute; top: 12px; right: 12px; background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s;" title="Remove Color Group">
            <i class="fas fa-trash-can" style="font-size: 0.8rem;"></i>
        </button>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; margin-right: 28px;">
            <div class="form-group" style="margin-bottom: 0;">
                <label class="form-label">Color <span class="required-star">*</span></label>
                <select class="form-control form-select color-id-input" required>
                    <option value="">— Choose Color —</option>
                    @foreach (var c in Model.Colors)
                    {
                        <option value="@c.Value">@c.Text</option>
                    }
                </select>
            </div>
            
            <div class="form-group" style="margin-bottom: 0;">
                <label class="form-label">Color-Specific Images</label>
                <input type="file" class="form-control color-images-input" accept="image/*" multiple style="padding: 6px 12px;" />
                <div class="color-images-preview-grid" style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px;"></div>
            </div>
        </div>

        <div style="border-top: 1px dashed var(--border-color); padding-top: 16px; margin-top: 16px;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                <h4 style="font-size: 0.9rem; font-weight: 700; margin: 0; color: var(--text-secondary);"><i class="fas fa-ruler"></i> Available Sizes &amp; Stock</h4>
                <button type="button" class="btn-secondary-sm add-size-btn" style="padding: 4px 10px; font-size: 0.75rem;">
                    <i class="fas fa-plus"></i> Add Size
                </button>
            </div>

            <div class="sizes-container" style="display: flex; flex-direction: column; gap: 8px;">
                @* Sizes rows injected here *@
            </div>
        </div>
    </div>
</template>

<template id="sizeRowTemplate">
    <div class="variant-row" style="display: grid; grid-template-columns: 1fr 80px 60px auto; gap: 10px; align-items: center; background: rgba(0,0,0,0.1); padding: 8px 12px; border-radius: 8px;">
        <input type="hidden" class="variant-id-input" value="" />
        <div class="form-group" style="margin-bottom: 0; gap: 4px;">
            <select class="form-control form-select variant-size-select" required style="padding: 6px 10px; font-size: 0.85rem;">
                <option value="">— Size —</option>
                @foreach (var s in Model.Sizes)
                {
                    <option value="@s.Value">@s.Text</option>
                }
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 0; gap: 4px;">
            <input type="number" class="form-control variant-qty-input" min="0" placeholder="Qty" required style="padding: 6px 10px; font-size: 0.85rem;" />
        </div>
        <div class="form-group" style="margin-bottom: 0; display: flex; flex-direction: column; align-items: center; gap: 2px;">
            <label class="form-label-sm" style="font-size: 0.7rem; margin: 0;">Active</label>
            <input type="checkbox" class="form-checkbox variant-active-checkbox" checked value="true" />
        </div>
        <button type="button" class="btn-remove-variant" style="padding: 6px; width: 28px; height: 28px; border-radius: 6px; font-size: 0.8rem; line-height: 1;" title="Remove Size">
            <i class="fas fa-xmark"></i>
        </button>
    </div>
</template>

<style>
    .form-grid-two-col {
        display: grid;
        grid-template-columns: 1fr 420px;
        gap: 24px;
        align-items: start;
    }
    .form-column { display: flex; flex-direction: column; gap: 24px; }
    .form-card { padding: 28px; }
    .form-card-title {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 22px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--text-primary);
    }
    .form-card-title i { color: var(--accent); }
    .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
    .form-label { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); }
    .form-label-sm { font-size: 0.8rem; font-weight: 600; color: var(--text-muted); }
    .required-star { color: #ef4444; }
    .form-control {
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 10px 14px;
        color: var(--text-primary);
        font-size: 0.9rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        width: 100%;
        box-sizing: border-box;
    }
    .form-control:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    }
    .form-select { cursor: pointer; }
    .form-textarea { min-height: 110px; resize: vertical; }
    .form-row-two { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .field-error { font-size: 0.8rem; color: #ef4444; }

    /* Upload zone */
    .image-upload-zone {
        border: 2px dashed var(--border-color);
        border-radius: 12px;
        padding: 32px 20px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        position: relative;
    }
    .image-upload-zone:hover { border-color: var(--accent); background: rgba(99,102,241,0.04); }
    .upload-icon { font-size: 2rem; color: var(--accent); margin-bottom: 10px; }
    .upload-text { font-weight: 600; margin: 0 0 4px; }
    .upload-subtext { font-size: 0.8rem; color: var(--text-muted); margin: 0; }
    .file-input-hidden {
        position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer;
    }

    /* Image previews */
    .image-preview-wrap {
        position: relative;
        margin-top: 14px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border-color);
    }
    .image-preview-img { width: 100%; height: 200px; object-fit: cover; display: block; }
    .image-current-label {
        position: absolute; bottom: 8px; left: 8px;
        background: rgba(0,0,0,0.55); color: #fff;
        font-size: 0.75rem; font-weight: 600; padding: 3px 10px;
        border-radius: 20px;
    }
    .btn-remove-image {
        position: absolute; top: 8px; right: 8px;
        background: rgba(0,0,0,0.55); color: #fff;
        border: none; border-radius: 50%;
        width: 30px; height: 30px; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.85rem; transition: background 0.2s;
    }
    .btn-remove-image:hover { background: #ef4444; }

    .sub-images-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 14px; }
    .sub-image-thumb {
        position: relative; border-radius: 8px; overflow: hidden;
        border: 1px solid var(--border-color); aspect-ratio: 1;
    }
    .sub-image-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .sub-image-thumb .btn-remove-image { width: 24px; height: 24px; font-size: 0.75rem; }

    /* Variants */
    .variant-row {
        margin-bottom: 6px;
    }
    .btn-remove-variant {
        background: rgba(239,68,68,0.12); color: #ef4444;
        border: 1px solid rgba(239,68,68,0.25);
        border-radius: 8px; width: 36px; height: 36px;
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        transition: background 0.2s;
    }
    .btn-remove-variant:hover { background: #ef4444; color: #fff; }
    .form-checkbox { width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent); }
    .btn-secondary-sm {
        padding: 7px 14px; font-size: 0.82rem; font-weight: 600;
        border-radius: 8px; border: 1px solid var(--accent);
        background: rgba(99,102,241,0.1); color: var(--accent);
        cursor: pointer; display: flex; align-items: center; gap: 6px;
        transition: background 0.2s;
    }
    .btn-secondary-sm:hover { background: rgba(99,102,241,0.2); }

    /* Form actions */
    .form-actions {
        display: flex; justify-content: flex-end; gap: 14px;
        margin-top: 24px; padding-top: 24px;
        border-top: 1px solid var(--border-color);
    }
    .btn-outline {
        padding: 11px 22px; font-size: 0.9rem; font-weight: 600;
        border-radius: 10px; border: 1px solid var(--border-color);
        background: transparent; color: var(--text-secondary);
        text-decoration: none; display: flex; align-items: center; gap: 8px;
        transition: border-color 0.2s, color 0.2s;
    }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

    @@media (max-width: 900px) {
        .form-grid-two-col { grid-template-columns: 1fr; }
    }
</style>

@section Scripts {
    <script>
        // ── Main image new upload preview ──────────────────────────────────────────
        const mainInput = document.getElementById('mainImageInput');
        const newMainPreview = document.getElementById('newMainImagePreview');
        const newMainImg = document.getElementById('newMainPreviewImg');
        const removeNewMainBtn = document.getElementById('removeNewMainImage');
        const existingMainWrap = document.getElementById('existingMainImageWrap');

        mainInput.addEventListener('change', () => {
            const file = mainInput.files[0];
            if (file) {
                newMainImg.src = URL.createObjectURL(file);
                newMainPreview.style.display = 'block';
                if (existingMainWrap) existingMainWrap.style.display = 'none';
            }
        });

        if (removeNewMainBtn) {
            removeNewMainBtn.addEventListener('click', () => {
                mainInput.value = '';
                newMainImg.src = '';
                newMainPreview.style.display = 'none';
                if (existingMainWrap) existingMainWrap.style.display = 'block';
            });
        }

        // ── Sub images new upload preview ──────────────────────────────────────────
        const subInput = document.getElementById('subImagesInput');
        const newSubGrid = document.getElementById('newSubImagesGrid');
        let newSubFiles = [];

        subInput.addEventListener('change', () => {
            Array.from(subInput.files).forEach(file => {
                newSubFiles.push(file);
                renderSubThumb(file);
            });
        });

        function renderSubThumb(file) {
            const wrap = document.createElement('div');
            wrap.className = 'sub-image-thumb';
            const img = document.createElement('img');
            img.src = URL.createObjectURL(file);
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'btn-remove-image';
            btn.style.cssText = 'width:24px;height:24px;font-size:0.7rem;';
            btn.innerHTML = '<i class="fas fa-xmark"></i>';
            btn.addEventListener('click', () => {
                newSubFiles = newSubFiles.filter(f => f !== file);
                wrap.remove();
                syncSubInput();
            });
            wrap.appendChild(img);
            wrap.appendChild(btn);
            newSubGrid.appendChild(wrap);
        }

        function syncSubInput() {
            const dt = new DataTransfer();
            newSubFiles.forEach(f => dt.items.add(f));
            subInput.files = dt.files;
        }

        // ── Nested Color & Size Manager ────────────────────────────────────────────
        const colorsContainer = document.getElementById('colorsContainer');
        const addColorBtn = document.getElementById('addColorBtn');
        const noColorsMsg = document.getElementById('noColorsMsg');
        const colorGroupTemplate = document.getElementById('colorGroupTemplate');
        const sizeRowTemplate = document.getElementById('sizeRowTemplate');

        // Setup existing remove listeners
        document.querySelectorAll('.btn-remove-color').forEach(btn => {
            btn.addEventListener('click', () => {
                btn.closest('.color-group').remove();
                checkNoColorsMsg();
            });
        });

        document.querySelectorAll('.btn-remove-variant').forEach(btn => {
            btn.addEventListener('click', () => {
                btn.closest('.variant-row').remove();
            });
        });

        document.querySelectorAll('.btn-remove-existing-color-image').forEach(btn => {
            btn.addEventListener('click', () => {
                btn.closest('.existing-color-image-thumb').remove();
            });
        });

        document.querySelectorAll('.add-size-btn').forEach(btn => {
            const container = btn.closest('.color-group').querySelector('.sizes-container');
            btn.addEventListener('click', () => {
                const sizeWrap = document.createElement('div');
                sizeWrap.innerHTML = sizeRowTemplate.innerHTML.trim();
                const sizeNode = sizeWrap.firstChild;

                sizeNode.querySelector('.btn-remove-variant').addEventListener('click', () => {
                    sizeNode.remove();
                });

                container.appendChild(sizeNode);
            });
        });

        // Setup color images preview for initial existing color groups
        document.querySelectorAll('.color-group').forEach(groupNode => {
            setupColorImagesPreview(groupNode);
        });

        // Add Color Group handler
        addColorBtn.addEventListener('click', () => {
            if (noColorsMsg) noColorsMsg.style.display = 'none';
            
            const groupWrap = document.createElement('div');
            groupWrap.innerHTML = colorGroupTemplate.innerHTML.trim();
            const groupNode = groupWrap.firstChild;

            const sizesContainer = groupNode.querySelector('.sizes-container');
            const addSizeBtn = groupNode.querySelector('.add-size-btn');
            const removeColorBtn = groupNode.querySelector('.btn-remove-color');
            
            // Add Size Row Event handler
            addSizeBtn.addEventListener('click', () => {
                const sizeWrap = document.createElement('div');
                sizeWrap.innerHTML = sizeRowTemplate.innerHTML.trim();
                const sizeNode = sizeWrap.firstChild;

                sizeNode.querySelector('.btn-remove-variant').addEventListener('click', () => {
                    sizeNode.remove();
                });

                sizesContainer.appendChild(sizeNode);
            });

            // Trigger one size automatically
            addSizeBtn.click();

            // Setup color images multi-file preview for new group
            setupColorImagesPreview(groupNode);

            // Handle color group remove button click
            removeColorBtn.addEventListener('click', () => {
                groupNode.remove();
                checkNoColorsMsg();
            });

            colorsContainer.appendChild(groupNode);
        });

        function setupColorImagesPreview(groupNode) {
            const fileInput = groupNode.querySelector('.color-images-input');
            const previewGrid = groupNode.querySelector('.color-images-preview-grid');
            if (!fileInput || !previewGrid) return;

            let colorFiles = [];

            fileInput.addEventListener('change', () => {
                Array.from(fileInput.files).forEach(file => {
                    colorFiles.push(file);
                    renderColorThumb(file);
                });
                syncInput();
            });

            function renderColorThumb(file) {
                const wrap = document.createElement('div');
                wrap.style.cssText = 'width: 55px; height: 55px; border-radius: 8px; overflow: hidden; border: 1px solid var(--border-color); position: relative;';
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.style.cssText = 'width: 100%; height: 100%; object-fit: cover;';
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.style.cssText = 'position: absolute; top: 2px; right: 2px; background: rgba(0,0,0,0.6); color: #fff; border: none; border-radius: 50%; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 0.65rem;';
                btn.innerHTML = '<i class="fas fa-xmark"></i>';
                btn.addEventListener('click', () => {
                    colorFiles = colorFiles.filter(f => f !== file);
                    wrap.remove();
                    syncInput();
                });
                wrap.appendChild(img);
                wrap.appendChild(btn);
                previewGrid.appendChild(wrap);
            }

            function syncInput() {
                const dt = new DataTransfer();
                colorFiles.forEach(f => dt.items.add(f));
                fileInput.files = dt.files;
            }
        }

        function checkNoColorsMsg() {
            if (noColorsMsg && colorsContainer.querySelectorAll('.color-group').length === 0) {
                noColorsMsg.style.display = 'block';
            }
        }

        // Re-index all color groups and nested variants before submit so they bind consecutively starting from 0 (using ProductColors[...])
        document.getElementById('editProductForm').addEventListener('submit', (e) => {
            const colorGroups = colorsContainer.querySelectorAll('.color-group');
            if (colorGroups.length === 0) {
                alert('Please add at least one color group with sizes.');
                e.preventDefault();
                return;
            }

            colorGroups.forEach((group, cIdx) => {
                // Set ProductColorId name
                const pcIdInput = group.querySelector('.product-color-id-input');
                if (pcIdInput) {
                    pcIdInput.name = `ProductColors[${cIdx}].ProductColorId`;
                }

                // Set ColorId name
                const colorSelect = group.querySelector('.color-id-input');
                colorSelect.name = `ProductColors[${cIdx}].ColorId`;
                
                // Set NewImages name
                const fileInput = group.querySelector('.color-images-input');
                fileInput.name = `ProductColors[${cIdx}].NewImages`;

                // Set ExistingImages names
                const existingThumbs = group.querySelectorAll('.existing-color-image-thumb');
                existingThumbs.forEach((thumb, eIdx) => {
                    const idInput = thumb.querySelector('.existing-image-id');
                    const urlInput = thumb.querySelector('.existing-image-url');
                    if (idInput) idInput.name = `ProductColors[${cIdx}].ExistingImages[${eIdx}].ImageUrlId`;
                    if (urlInput) urlInput.name = `ProductColors[${cIdx}].ExistingImages[${eIdx}].ImageUrl`;
                });

                // Set Size, Qty and Active name attributes
                const sizeRows = group.querySelectorAll('.variant-row');
                sizeRows.forEach((row, sIdx) => {
                    row.querySelector('.variant-size-select').name = `ProductColors[${cIdx}].Variants[${sIdx}].SizeId`;
                    row.querySelector('.variant-qty-input').name = `ProductColors[${cIdx}].Variants[${sIdx}].Quantity`;
                    
                    const activeCheck = row.querySelector('.variant-active-checkbox');
                    activeCheck.name = `ProductColors[${cIdx}].Variants[${sIdx}].IsActive`;

                    const vIdInput = row.querySelector('.variant-id-input');
                    if (vIdInput) {
                        vIdInput.name = `ProductColors[${cIdx}].Variants[${sIdx}].VariantId`;
                    }
                });
            });
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}