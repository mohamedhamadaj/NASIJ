<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel | Clothes Store</title>
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <!-- Custom Admin Stylesheet -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar Navigation -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-brand">
                <i class="fas fa-tshirt brand-icon"></i>
                <span class="brand-name">VogueAdmin</span>
            </div>
            
            <ul class="sidebar-menu">
                <li class="menu-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-chart-pie"></i>
                        <span class="menu-text">Dashboard</span>
                    </a>
                </li>
                <li class="menu-item @(ViewData["ActivePage"]?.ToString() == "Products" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Products">
                        <i class="fas fa-boxes-stacked"></i>
                        <span class="menu-text">Clothes Stock</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a asp-area="Admin" asp-controller="Category" asp-action="index">
                        <i class="fas fa-boxes-stacked"></i>
                        <span class="menu-text">Category</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a asp-area="Admin" asp-controller="Product" asp-action="index">
                        <i class="fas fa-boxes-stacked"></i>
                        <span class="menu-text">Products</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="#">
                        <i class="fas fa-shopping-bag"></i>
                        <span class="menu-text">Orders</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="#">
                        <i class="fas fa-users"></i>
                        <span class="menu-text">Customers</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="#">
                        <i class="fas fa-sliders"></i>
                        <span class="menu-text">Settings</span>
                    </a>
                </li>
            </ul>
            
            <div class="sidebar-footer">
                <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=100&q=80" alt="Avatar" class="sidebar-avatar" />
                <div class="sidebar-user-info">
                    <span class="user-name">Sarah Connor</span>
                    <span class="user-role">Store Manager</span>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="admin-main">
            <!-- Navbar -->
            <nav class="admin-navbar">
                <div class="navbar-left">
                    <button class="sidebar-toggle" id="sidebarToggle" title="Toggle Sidebar">
                        <i class="fas fa-bars-staggered"></i>
                    </button>
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Search inventory, orders..." />
                    </div>
                </div>
                <div class="navbar-right">
                    <button class="nav-icon-btn" id="themeToggle" title="Switch Theme">
                        <i class="fas fa-sun"></i>
                    </button>
                    <button class="nav-icon-btn" title="View Notifications">
                        <i class="fas fa-bell"></i>
                        <span class="btn-badge"></span>
                    </button>
                    <button class="nav-icon-btn" title="Sign Out">
                        <i class="fas fa-right-from-bracket"></i>
                    </button>
                </div>
            </nav>

            <!-- Page Body -->
            <main class="content-body">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Custom Admin JavaScript -->
    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
